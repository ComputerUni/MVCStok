@using MvcStok.Models.Entity
@using PagedList
@using PagedList.Mvc
@model PagedList.IPagedList<TBLKATEGORILER>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<h2>Kategori Listesi</h2>

<table class="table table-bordered">
    <tr>
        <th>KATEGORI ID </th>
        <th>KATEGORI ADI</th>
        <th>SİL</th>
        <th>GÜNCELLE</th>
    </tr>
    <tbody>
        @foreach(var kategori in Model)
        {
        <tr>
            <th>@kategori.KATEGORIID</th>
            <td>@kategori.KATEGORIAD</td>
            <td><a href="/KATEGORI/SIL/@kategori.KATEGORIID" class="btn btn-danger">SİL</a></td>
            <td class="d-flex justify-content-center"><a href="/KATEGORI/KategoriGetir/@kategori.KATEGORIID" class="btn btn-info">GÜNCELLE</a></td>
        </tr>
        }
    </tbody>
</table>
@Html.PagedListPager((IPagedList)Model, sayfa=>Url.Action("Index", new { sayfa }))
<a href="/KATEGORI/YeniKategori/" class="btn btn-primary">YENİ KATEGORİ EKLE</a>
